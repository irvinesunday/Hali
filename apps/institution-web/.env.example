# Hali Institution Web — environment variables template.
#
# Copy to .env.local for local development. Never commit real values.
# The env schema for this app is intentionally minimal: API base URL,
# feature-flag endpoint, and a build-time app version marker. No
# secrets, no backend configuration. Session tokens are httpOnly
# cookies set server-side — there is nothing to put here that the
# browser cannot already see.

# Base URL of the Hali API. Override per environment.
# Example for local backend: http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# Feature flag resolution endpoint.
# Resolves to the client-visible flag set (see @hali/contracts
# ResolvedFeatureFlagsResponse).
VITE_FEATURE_FLAGS_ENDPOINT=/v1/feature-flags

# App version marker, surfaced in telemetry context (issue #207).
# In CI this is substituted at build time; for local use, leave as-is.
VITE_APP_VERSION=0.0.0-local
