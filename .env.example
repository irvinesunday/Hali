# =============================================================================
# Hali MVP – Environment Configuration
# Authority: mvp_locked_decisions.md (project root)
# Copy to .env for local development. Never commit .env to version control.
# =============================================================================

# App
ASPNETCORE_ENVIRONMENT=Development
HALI_APP_BASE_URL=http://localhost:8080
DEFAULT_COUNTRY_CODE=KE
DEFAULT_TIMEZONE=Africa/Nairobi

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hali
POSTGRES_USER=hali
POSTGRES_PASSWORD=changeme
DATABASE_URL=Host=localhost;Port=5432;Database=hali;Username=hali;Password=changeme

# PostGIS / Spatial
POSTGIS_ENABLED=true
H3_RESOLUTION=9

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=localhost:6379

# Auth / JWT
JWT_ISSUER=hali-api
JWT_AUDIENCE=hali-platform
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=30

# OTP / SMS — Africa's Talking (mvp_locked_decisions.md §3)
OTP_LENGTH=6
OTP_TTL_MINUTES=10
