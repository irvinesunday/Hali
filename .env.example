AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=

# Anthropic / CSI-NLP (mvp_locked_decisions.md §1)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
NLP_EXTRACTION_TIMEOUT_SECONDS=20

# Geocoding — Nominatim/OSM (mvp_locked_decisions.md §6)
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=HaliMVP/1.0 your-email@example.com
GEOCODING_TIMEOUT_SECONDS=10
GOOGLE_MAPS_API_KEY=

# Expo Push Notifications (mvp_locked_decisions.md §7)
PUSH_PROVIDER=expo
EXPO_ACCESS_TOKEN=
EXPO_PROJECT_ID=

# CIVIS Shared Constants (mvp_locked_decisions.md §9)
CIVIS_MIN_UNIQUE_DEVICES=2
CIVIS_JOIN_THRESHOLD=0.65
CIVIS_RESTORATION_RATIO=0.60
CIVIS_MIN_RESTORATION_AFFECTED_VOTES=2
CIVIS_CONTEXT_EDIT_WINDOW_MINUTES=2
CIVIS_WRAB_ROLLING_WINDOW_DAYS=30

# CIVIS Category Tuning (mvp_locked_decisions.md §9)
CIVIS_ROADS_BASE_FLOOR=2
CIVIS_ROADS_HALF_LIFE_HOURS=18
CIVIS_ROADS_MACF_MIN=2
CIVIS_ROADS_MACF_MAX=6

CIVIS_TRANSPORT_BASE_FLOOR=2
CIVIS_TRANSPORT_HALF_LIFE_HOURS=8
CIVIS_TRANSPORT_MACF_MIN=2
CIVIS_TRANSPORT_MACF_MAX=5

CIVIS_ELECTRICITY_BASE_FLOOR=2
CIVIS_ELECTRICITY_HALF_LIFE_HOURS=12
CIVIS_ELECTRICITY_MACF_MIN=2
CIVIS_ELECTRICITY_MACF_MAX=6

CIVIS_WATER_BASE_FLOOR=2
CIVIS_WATER_HALF_LIFE_HOURS=24
CIVIS_WATER_MACF_MIN=2
CIVIS_WATER_MACF_MAX=7

CIVIS_ENVIRONMENT_BASE_FLOOR=2
CIVIS_ENVIRONMENT_HALF_LIFE_HOURS=36
CIVIS_ENVIRONMENT_MACF_MIN=2
CIVIS_ENVIRONMENT_MACF_MAX=6

CIVIS_SAFETY_BASE_FLOOR=2
CIVIS_SAFETY_HALF_LIFE_HOURS=18
CIVIS_SAFETY_MACF_MIN=2
CIVIS_SAFETY_MACF_MAX=6

CIVIS_INFRASTRUCTURE_BASE_FLOOR=2
CIVIS_INFRASTRUCTURE_HALF_LIFE_HOURS=24
CIVIS_INFRASTRUCTURE_MACF_MIN=2
CIVIS_INFRASTRUCTURE_MACF_MAX=6

# Data Protection — at-rest encryption of the key ring (#243)
# The Data Protection key ring is persisted in PostgreSQL
# (data_protection_keys). The variables below configure at-rest
# encryption of that ring via an X.509 certificate.
#
# REQUIRED in staging and production BEFORE institution users are
# onboarded. Production will THROW at startup in BOTH of these cases
# (fail-fast — no silent-unprotected fallback):
#   * DATA_PROTECTION_CERT_PATH is unset at all
#   * DATA_PROTECTION_CERT_PATH is set but the file is missing or
#     cannot be loaded
#
# Non-production behaviour when DATA_PROTECTION_CERT_PATH is unset:
#   * Windows: Data Protection falls back to DPAPI (user-scoped) —
#     dev-machine escape hatch only, never canonical for staging /
#     production. A WARNING is logged at startup.
#   * Other platforms (Linux/macOS): keys are stored UNPROTECTED.
#     A WARNING is logged at startup. Acceptable for local dev only.
#
# Generate a self-signed cert (keep the .pfx outside the repo):
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 3650 -nodes
#   openssl pkcs12 -export -out hali-dp.pfx -inkey key.pem -in cert.pem
# Never commit the .pfx or its password.
DATA_PROTECTION_CERT_PATH=
DATA_PROTECTION_CERT_PASSWORD=

# Logging / Observability
SERILOG_MINIMUM_LEVEL=Information
SENTRY_DSN=
# OpenTelemetry — set to emit traces/metrics to an OTLP collector
# docker-compose sets this to http://otel-collector:4317 automatically
OTEL_EXPORTER_OTLP_ENDPOINT=

# CIVIS Governance (added — was missing from initial env)
CIVIS_GOVERNANCE_BASE_FLOOR=2
CIVIS_GOVERNANCE_HALF_LIFE_HOURS=24
CIVIS_GOVERNANCE_MACF_MIN=2
CIVIS_GOVERNANCE_MACF_MAX=6

# CIVIS Decay — ratio of live_mass/effective_wrab below which decay triggers a state transition.
# Must be lower than activation threshold to prevent cluster state flicker.
CIVIS_DEACTIVATION_THRESHOLD=0.5
